# Copie este arquivo para ".env" e preencha com seus dados reais.

# String de conexão com o PostgreSQL
DATABASE_URL="postgresql://usuario:senha@localhost:5432/assistencia_tecnica?schema=public"

# Porta em que a API vai rodar
PORT=3333

# Segredo usado para assinar os tokens JWT (troque por um valor aleatório forte)
JWT_SECRET="troque-por-um-segredo-forte-aqui"
JWT_EXPIRES_IN="7d"

# URL do frontend, usada para montar o link de acompanhamento enviado ao
# cliente nas notificações (ex: https://meusistema.com.br)
FRONTEND_URL="http://localhost:5173"

# ----------------------------------------------------------------------------
# NOTIFICAÇÕES AO CLIENTE (SMS / WhatsApp a cada mudança de status)
# ----------------------------------------------------------------------------

# "console"  -> modo simulado, só imprime a mensagem no log (padrão, não
#               precisa de nenhuma credencial — bom para desenvolvimento)
# "twilio"   -> envia de verdade via Twilio (preencha as variáveis abaixo)
NOTIFICATION_PROVIDER="console"

# Canal usado quando o provedor é "twilio": "WHATSAPP" ou "SMS"
NOTIFICATION_CHANNEL="WHATSAPP"

# Credenciais da Twilio (https://console.twilio.com) — só necessárias se
# NOTIFICATION_PROVIDER="twilio"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# Número habilitado para WhatsApp no Twilio Sandbox/produção, com o prefixo:
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
# Número de SMS da Twilio, formato E.164:
TWILIO_SMS_FROM=""
